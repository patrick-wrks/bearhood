# -----------------------------------------------------------------------
# Required: Supabase client keys
# Get these from: Supabase dashboard → Settings → API
# -----------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------
# Required for auth email redirects (magic link, password reset, sign-up
# confirmation). Supabase includes this URL in the email links so users
# land back on the right page.
#
# Local dev: http://localhost:3000
# GitHub Pages: https://patrick-wrks.github.io/bearhood
#
# Also add this value to GitHub Actions secrets as NEXT_PUBLIC_SITE_URL
# AND register it in Supabase: Authentication → URL Configuration →
# Redirect URLs (add both http://localhost:3000/** and the Pages URL)
# -----------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------
# Optional: social link overrides for the footer
# -----------------------------------------------------------------------
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://instagram.com/yourbearhood
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=
# NEXT_PUBLIC_SOCIAL_TIKTOK_URL=
